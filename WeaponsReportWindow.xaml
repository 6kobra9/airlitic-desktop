<Window x:Class="AirLiticApp.WeaponsReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AirLiticApp"
        Title="Звіт по засобам" Height="760" Width="980"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- Вертикальні стовпчики (якщо знадобиться): MaxHeight -->
        <local:DoubleToBarHeightConverter x:Key="BarHeightConverter" MaxHeight="280" />
        <!-- Горизонтальні смуги: той самий клас, MaxHeight = макс. ширина смуги (пікс.) -->
        <local:DoubleToBarHeightConverter x:Key="BarWidthConverter" MaxHeight="360" />
        <local:DoubleToBarHeightConverter x:Key="BarWidthConverterLost" MaxHeight="280" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabControl"
                    Grid.Row="0">
            <TabItem Header="Таблиці">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Загальний звіт" Grid.Row="0" Margin="0,0,0,8">
                        <DockPanel Margin="0,4,0,0">
                            <DataGrid x:Name="ReportGrid"
                                      DockPanel.Dock="Top"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Margin="0,0,0,8"/>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Звіт по невдалих вильотах (причини втрати)" Grid.Row="1" Margin="0,0,0,8">
                        <DockPanel Margin="0,4,0,0">
                            <DataGrid x:Name="LostReportGrid"
                                      DockPanel.Dock="Top"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Margin="0,0,0,8"/>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Графіки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Гістограма KPI по засобам" Grid.Row="0" Margin="0,0,0,8">
                        <DockPanel Margin="0,4,0,0">
                            <!-- Легенда цветов (правый верхний угол) -->
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="12,0,0,8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                    <Border Width="14" Height="14" Background="#BFE3FF" BorderBrush="#245A7A" BorderThickness="1"/>
                                    <TextBlock Text="Загалом (вильоти)" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                    <Border Width="14" Height="14" Background="#3A7BD5" BorderBrush="#245A7A" BorderThickness="1"/>
                                    <TextBlock Text="Ураження" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="14" Height="14" Background="#86BFF8" BorderBrush="#245A7A" BorderThickness="1"/>
                                    <TextBlock Text="Неуражень" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="Довжина смуги — відносно найбільшої кількості вильотів"
                                       FontSize="9"
                                       Foreground="#666"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <!-- Горизонтальні смуги: підпис зліва, довжина ∼ вильоти -->
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Засіб"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#245A7A"
                                           VerticalAlignment="Top"
                                           Margin="0,8,10,0"
                                           TextWrapping="Wrap"
                                           MaxWidth="72"/>
                                <ScrollViewer x:Name="MainBarChartPanel"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="280"
                                              Margin="0,0,0,0">
                                    <ItemsControl ItemsSource="{Binding MainStackItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3,0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Label}"
                                                               VerticalAlignment="Center"
                                                               FontSize="10"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,8,0"/>
                                                    <Grid Grid.Column="1"
                                                          Height="30"
                                                          Width="{Binding TotalPercent, Converter={StaticResource BarWidthConverter}}"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center">
                                                        <Border Background="#BFE3FF"
                                                                Opacity="0.45"
                                                                CornerRadius="2"/>
                                                        <StackPanel Orientation="Horizontal"
                                                                    VerticalAlignment="Stretch"
                                                                    HorizontalAlignment="Left"
                                                                    Margin="0,3,0,3">
                                                            <Border Width="{Binding HitsPercent, Converter={StaticResource BarWidthConverter}}"
                                                                    Background="#3A7BD5"
                                                                    Opacity="0.95"
                                                                    CornerRadius="2,0,0,2"
                                                                    MinWidth="0">
                                                                <TextBlock Text="{Binding HitsCount, StringFormat={}{0}}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="9"
                                                                           Foreground="White"/>
                                                            </Border>
                                                            <Border Width="{Binding MissesPercent, Converter={StaticResource BarWidthConverter}}"
                                                                    Background="#86BFF8"
                                                                    Opacity="0.95"
                                                                    CornerRadius="0,2,2,0"
                                                                    MinWidth="0">
                                                                <TextBlock Text="{Binding MissesCount, StringFormat={}{0}}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="9"
                                                                           Foreground="#0B3554"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding TotalCount, StringFormat='Всього: {0}'}"
                                                               VerticalAlignment="Center"
                                                               FontSize="9"
                                                               Foreground="#245A7A"
                                                               Margin="8,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Гістограма KPI по причинам неуражень" Grid.Row="1" Margin="0,0,0,8">
                        <DockPanel Margin="0,4,0,0">
                            <!-- Легенда: один рядок під одним (як у першого графіка) -->
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="12,0,0,8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Width="14" Height="14" Background="#1B4F72" BorderBrush="#245A7A" BorderThickness="1"/>
                                    <TextBlock Text="Помилка пілота" Margin="6,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Width="14" Height="14" Background="#2E6FBF" BorderBrush="#245A7A" BorderThickness="1"/>
                                    <TextBlock Text="Технічні помилки" Margin="6,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Width="14" Height="14" Background="#3A7BD5" BorderBrush="#245A7A" BorderThickness="1"/>
                                    <TextBlock Text="Вороже збиття" Margin="6,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Width="14" Height="14" Background="#4F91E6" BorderBrush="#245A7A" BorderThickness="1"/>
                                    <TextBlock Text="Реб свій" Margin="6,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Width="14" Height="14" Background="#66A6FF" BorderBrush="#245A7A" BorderThickness="1"/>
                                    <TextBlock Text="Реб противника" Margin="6,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="14" Height="14" Background="#BFE3FF" BorderBrush="#245A7A" BorderThickness="1"/>
                                    <TextBlock Text="Погодні умови" Margin="6,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="Довжина смуги — відносно найбільшої причини"
                                       FontSize="9"
                                       Foreground="#666"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Причина"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#245A7A"
                                           VerticalAlignment="Top"
                                           Margin="0,8,10,0"
                                           TextWrapping="Wrap"
                                           MaxWidth="72"/>
                                <ScrollViewer x:Name="LostBarChartPanel"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="280"
                                              Margin="0,0,0,0">
                                    <ItemsControl ItemsSource="{Binding LostReasonItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Label}"
                                                               VerticalAlignment="Center"
                                                               FontSize="10"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,8,0"/>
                                                    <Border Grid.Column="1"
                                                            Height="22"
                                                            Width="{Binding HeightPercent, Converter={StaticResource BarWidthConverterLost}}"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            CornerRadius="2"
                                                            Background="{Binding BarBrush}">
                                                        <TextBlock Text="{Binding Count, StringFormat={}{0}}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="10"
                                                                   Foreground="{Binding CountForeground}"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <Button Grid.Row="1"
                Content="Закрити"
                Width="110"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
