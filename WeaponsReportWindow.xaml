<Window x:Class="AirLiticApp.WeaponsReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AirLiticApp"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Звіти" Height="820" Width="1120"
        MinHeight="540" MinWidth="880"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- Ширина сегментів смуги = % × (ActualWidth ScrollViewer мінус підпис/KPI); масштабується з вікном -->
        <local:ChartTrackSegmentWidthConverter x:Key="MainTrackWidthConv" ChromeReserve="218" MinTrackWidth="40"/>
        <local:ChartTrackSegmentWidthConverter x:Key="LostTrackWidthConv" ChromeReserve="218" MinTrackWidth="40"/>

        <Style x:Key="ReportColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   Padding="2,0"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChartPanelBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#C4C4C4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="#FDFDFD"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14" LastChildFill="True" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <!-- Низ: кнопка -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Закрити" Width="110" Click="CloseButton_Click"/>
        </StackPanel>

        <!-- Верх: параметри -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,12" Margin="0,0,0,10" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220" MinWidth="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Тип звіту" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="ReportTypeCombo" Grid.Column="1" SelectedIndex="0"
                          SelectionChanged="ReportTypeCombo_SelectionChanged" VerticalAlignment="Center">
                    <ComboBoxItem Content="Звіт по засобам" Tag="{x:Static local:ReportKind.Weapons}"/>
                    <ComboBoxItem Content="Звіт по пілотам" Tag="{x:Static local:ReportKind.Pilots}"/>
                </ComboBox>
                <TextBlock Grid.Column="2" Text="Дата з" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <DatePicker x:Name="FromDatePicker" Grid.Column="3" SelectedDateFormat="Short" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Дата по" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <DatePicker x:Name="ToDatePicker" Grid.Column="5" SelectedDateFormat="Short" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="7" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Button x:Name="ExportExcelButton"
                            Content="Вивантажити вExcel"
                            Width="110"
                            Margin="0,0,8,0"
                            Click="ExportExcelButton_Click"
                            IsEnabled="False"
                            ToolTip="Зберегти таблиці, дані графіків та зображення графіків у файл .xlsx"/>
                    <Button x:Name="GenerateButton"
                            Content="Сформувати"
                            Width="130"
                            IsDefault="True"
                            Click="GenerateButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Дві рівні половини по вертикалі: основний звіт | невдалі вильоти -->
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- === Ряд 0: таблиця + графік (50%) === -->
            <GroupBox x:Name="MainTableGroup" Grid.Row="0" Padding="12,10" Margin="0,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="ReportGrid"
                                  Grid.Row="0"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  ColumnHeaderStyle="{StaticResource ReportColumnHeaderStyle}"
                                  ColumnHeaderHeight="{x:Static sys:Double.NaN}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalAlignment="Stretch"/>
                        <!-- Футер: сума лише «Кіл-ть вильотів» -->
                        <Border x:Name="MainTableFooterPanel"
                                Grid.Row="1"
                                Margin="0,6,0,0"
                                Visibility="Collapsed"
                                BorderBrush="#C4C4C4"
                                BorderThickness="1"
                                CornerRadius="0,0,2,2"
                                Background="#F4F6F8"
                                SnapsToDevicePixels="True">
                            <TextBlock x:Name="MainTableFooterSumText"
                                       Margin="10,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#222"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <Border x:Name="MainHitsChartGroup"
                            Grid.Column="2"
                            Style="{StaticResource ChartPanelBorder}"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="Вильоти по кожному рядку (горизонтальна шкала)"
                                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Вісь X — кількість вильотів (макс. по звіту); смуга: вдалі (уражено) → невдалі → інші."
                                           FontSize="10" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0"
                                                ToolTipService.ShowDuration="20000"
                                                ToolTipService.InitialShowDelay="200">
                                        <StackPanel.ToolTip>
                                            <TextBlock Text="Вдалі вильоти з результатом «уражено» за основною таблицею звіту (колонка з причиною «Уражено»)." TextWrapping="Wrap" MaxWidth="280"/>
                                        </StackPanel.ToolTip>
                                        <Border Width="12" Height="12" Background="#16A34A" Margin="0,0,6,0" VerticalAlignment="Center" Cursor="Hand"/>
                                        <TextBlock Text="Вдалі (уражено)" VerticalAlignment="Center" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0"
                                                ToolTipService.ShowDuration="20000"
                                                ToolTipService.InitialShowDelay="200">
                                        <StackPanel.ToolTip>
                                            <TextBlock Text="Невдалі вильоти за таблицею «невдалі вильоти» для цього ж пілота/засобу (сума по причинах втрати)." TextWrapping="Wrap" MaxWidth="280"/>
                                        </StackPanel.ToolTip>
                                        <Border Width="12" Height="12" Background="#DC2626" Margin="0,0,6,0" VerticalAlignment="Center" Cursor="Hand"/>
                                        <TextBlock Text="Невдалі вильоти" VerticalAlignment="Center" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                ToolTipService.ShowDuration="20000"
                                                ToolTipService.InitialShowDelay="200">
                                        <StackPanel.ToolTip>
                                            <TextBlock Text="Інші вильоти: не зараховані як ураження та не входять до невдалих за нижньою таблицею (решта до загальної кількості)." TextWrapping="Wrap" MaxWidth="280"/>
                                        </StackPanel.ToolTip>
                                        <Border Width="12" Height="12" Background="#94A3B8" Margin="0,0,6,0" VerticalAlignment="Center" Cursor="Hand"/>
                                        <TextBlock Text="Інші" VerticalAlignment="Center" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <ScrollViewer x:Name="MainChartScroll"
                                          Grid.Row="1"
                                          VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Stretch"
                                          Padding="0,0,2,0">
                                <ItemsControl ItemsSource="{Binding MainStackItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="{Binding MainChartItemMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Height="{Binding MainChartRowHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  ClipToBounds="True"
                                                  ToolTipService.ShowDuration="20000"
                                                  ToolTip="{Binding HoverSummary}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130" MinWidth="100"/>
                                                    <ColumnDefinition Width="*" MinWidth="160"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                           FontSize="{Binding MainChartLabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           MaxHeight="{Binding MainChartLabelMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <Border Grid.Column="1"
                                                        Height="{Binding MainChartTrackHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        VerticalAlignment="Center"
                                                        BorderBrush="#CBD5E1" BorderThickness="0,0,0,1"
                                                        Background="#F8FAFC" SnapsToDevicePixels="True">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                                Margin="{Binding MainChartBarPanelPadding, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Border Height="{Binding MainChartSegHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                VerticalAlignment="Center" CornerRadius="1" MinWidth="0" Margin="0,0,1,0"
                                                                Background="#16A34A"
                                                                ToolTipService.ShowDuration="20000"
                                                                ToolTipService.InitialShowDelay="200"
                                                                Cursor="Hand">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="Вдалі (уражено): кількість вильотів з результатом «уражено» за основною таблицею." TextWrapping="Wrap" MaxWidth="260"/>
                                                            </Border.ToolTip>
                                                            <TextBlock Text="{Binding SuccessCount, StringFormat={}{0}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       FontSize="{Binding MainChartSegTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="White"/>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource MainTrackWidthConv}">
                                                                    <Binding Path="SuccessTrackPercent"/>
                                                                    <Binding ElementName="MainChartScroll" Path="ActualWidth"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        <Border Height="{Binding MainChartSegHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                VerticalAlignment="Center" CornerRadius="1" MinWidth="0" Margin="0,0,1,0"
                                                                Background="#DC2626"
                                                                ToolTipService.ShowDuration="20000"
                                                                ToolTipService.InitialShowDelay="200"
                                                                Cursor="Hand">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="Невдалі вильоти: за таблицею невдалих вильотів для цього пілота/засобу." TextWrapping="Wrap" MaxWidth="260"/>
                                                            </Border.ToolTip>
                                                            <TextBlock Text="{Binding FailedCount, StringFormat={}{0}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       FontSize="{Binding MainChartSegTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="White"/>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource MainTrackWidthConv}">
                                                                    <Binding Path="FailedTrackPercent"/>
                                                                    <Binding ElementName="MainChartScroll" Path="ActualWidth"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        <Border Height="{Binding MainChartSegHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                VerticalAlignment="Center" CornerRadius="1" MinWidth="0"
                                                                Background="#94A3B8"
                                                                ToolTipService.ShowDuration="20000"
                                                                ToolTipService.InitialShowDelay="200"
                                                                Cursor="Hand">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="Інші вильоти: решта до загальної кількості (не ураження й не зведені до невдалих у нижньому звіті)." TextWrapping="Wrap" MaxWidth="260"/>
                                                            </Border.ToolTip>
                                                            <TextBlock Text="{Binding OtherCount, StringFormat={}{0}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       FontSize="{Binding MainChartSegTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="White"/>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource MainTrackWidthConv}">
                                                                    <Binding Path="OtherTrackPercent"/>
                                                                    <Binding ElementName="MainChartScroll" Path="ActualWidth"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding KpiDisplay}"
                                                           FontSize="{Binding MainChartLabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#0F172A"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" MinWidth="36"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock x:Name="MainChartAxisText"
                                       Grid.Row="2"
                                       FontSize="9"
                                       Foreground="#64748B"
                                       Margin="140,6,72,0"
                                       TextAlignment="Left"
                                       FontFamily="Consolas"/>

                            <TextBlock Grid.Row="3"
                                       Text="Довжина кольорової смуги відповідає загальній кількості вильотів у рядку відносно максимуму по звіту. KPI — з таблиці."
                                       FontSize="9" Foreground="#666" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- Проміжок між зонами -->
            <Rectangle Grid.Row="1" Fill="Transparent"/>

            <!-- === Ряд 2: таблиця + графік (50%) === -->
            <GroupBox x:Name="LostTableGroup" Grid.Row="2" Padding="12,10" Margin="0,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="LostReportGrid"
                                  Grid.Row="0"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  FrozenColumnCount="1"
                                  ColumnHeaderStyle="{StaticResource ReportColumnHeaderStyle}"
                                  ColumnHeaderHeight="{x:Static sys:Double.NaN}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalAlignment="Stretch"/>
                        <Border x:Name="LostTableFooterPanel"
                                Grid.Row="1"
                                Margin="0,6,0,0"
                                Visibility="Collapsed"
                                BorderBrush="#C4C4C4"
                                BorderThickness="1"
                                CornerRadius="0,0,2,2"
                                Background="#F4F6F8"
                                SnapsToDevicePixels="True">
                            <TextBlock x:Name="LostTableFooterSumText"
                                       Margin="10,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#222"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <Border x:Name="LostReasonsChartGroup"
                            Grid.Column="2"
                            Style="{StaticResource ChartPanelBorder}"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Причини втрати по кожному рядку (горизонтальна шкала)"
                                       FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <ScrollViewer x:Name="LostChartScroll"
                                          Grid.Row="1"
                                          VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Stretch"
                                          Padding="0,0,2,0">
                                <ItemsControl ItemsSource="{Binding LostStackItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="{Binding LostChartItemMargin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Height="{Binding LostChartRowHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  ClipToBounds="True"
                                                  ToolTipService.ShowDuration="20000"
                                                  ToolTip="{Binding HoverSummary}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130" MinWidth="100"/>
                                                    <ColumnDefinition Width="*" MinWidth="160"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                           FontSize="{Binding LostChartLabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           MaxHeight="{Binding LostChartLabelMaxHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <Border Grid.Column="1"
                                                        Height="{Binding LostChartTrackHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        VerticalAlignment="Center"
                                                        BorderBrush="#4C1D95" BorderThickness="0,0,0,1"
                                                        Background="#FAF5FF" SnapsToDevicePixels="True">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                                Margin="{Binding LostChartBarPanelPadding, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Border Height="{Binding LostChartSegHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                VerticalAlignment="Center" CornerRadius="1" MinWidth="0" Margin="0,0,1,0"
                                                                Background="#3B0764"
                                                                ToolTipService.ShowDuration="20000"
                                                                ToolTipService.InitialShowDelay="200"
                                                                Cursor="Hand">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="Помилка пілота: оцінка кількості втрат (KPI «помилка пілота» × невдалі вильоти)." TextWrapping="Wrap" MaxWidth="260"/>
                                                            </Border.ToolTip>
                                                            <TextBlock Text="{Binding PilotErrorCount, StringFormat={}{0}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       FontSize="{Binding LostChartSegTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="White"/>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource LostTrackWidthConv}">
                                                                    <Binding Path="PilotErrorTrackPercent"/>
                                                                    <Binding ElementName="LostChartScroll" Path="ActualWidth"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        <Border Height="{Binding LostChartSegHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                VerticalAlignment="Center" CornerRadius="1" MinWidth="0" Margin="0,0,1,0"
                                                                Background="#5B21B6"
                                                                ToolTipService.ShowDuration="20000"
                                                                ToolTipService.InitialShowDelay="200"
                                                                Cursor="Hand">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="Технічні помилки: оцінка втрат через технічні несправності." TextWrapping="Wrap" MaxWidth="260"/>
                                                            </Border.ToolTip>
                                                            <TextBlock Text="{Binding TechErrorCount, StringFormat={}{0}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       FontSize="{Binding LostChartSegTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="White"/>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource LostTrackWidthConv}">
                                                                    <Binding Path="TechErrorTrackPercent"/>
                                                                    <Binding ElementName="LostChartScroll" Path="ActualWidth"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        <Border Height="{Binding LostChartSegHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                VerticalAlignment="Center" CornerRadius="1" MinWidth="0" Margin="0,0,1,0"
                                                                Background="#7C2D92"
                                                                ToolTipService.ShowDuration="20000"
                                                                ToolTipService.InitialShowDelay="200"
                                                                Cursor="Hand">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="Вороже збиття: оцінка втрат через збиття супротивником." TextWrapping="Wrap" MaxWidth="260"/>
                                                            </Border.ToolTip>
                                                            <TextBlock Text="{Binding EnemyShotCount, StringFormat={}{0}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       FontSize="{Binding LostChartSegTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="White"/>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource LostTrackWidthConv}">
                                                                    <Binding Path="EnemyShotTrackPercent"/>
                                                                    <Binding ElementName="LostChartScroll" Path="ActualWidth"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        <Border Height="{Binding LostChartSegHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                VerticalAlignment="Center" CornerRadius="1" MinWidth="0" Margin="0,0,1,0"
                                                                Background="#A21CAF"
                                                                ToolTipService.ShowDuration="20000"
                                                                ToolTipService.InitialShowDelay="200"
                                                                Cursor="Hand">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="РЕБ свій: оцінка втрат через дію власного радіоелектронного подавлення." TextWrapping="Wrap" MaxWidth="260"/>
                                                            </Border.ToolTip>
                                                            <TextBlock Text="{Binding OwnRebCount, StringFormat={}{0}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       FontSize="{Binding LostChartSegTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="White"/>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource LostTrackWidthConv}">
                                                                    <Binding Path="OwnRebTrackPercent"/>
                                                                    <Binding ElementName="LostChartScroll" Path="ActualWidth"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        <Border Height="{Binding LostChartSegHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                VerticalAlignment="Center" CornerRadius="1" MinWidth="0" Margin="0,0,1,0"
                                                                Background="#C026D3"
                                                                ToolTipService.ShowDuration="20000"
                                                                ToolTipService.InitialShowDelay="200"
                                                                Cursor="Hand">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="РЕБ противника: оцінка втрат через РЕБ супротивника." TextWrapping="Wrap" MaxWidth="260"/>
                                                            </Border.ToolTip>
                                                            <TextBlock Text="{Binding EnemyRebCount, StringFormat={}{0}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       FontSize="{Binding LostChartSegTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="White"/>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource LostTrackWidthConv}">
                                                                    <Binding Path="EnemyRebTrackPercent"/>
                                                                    <Binding ElementName="LostChartScroll" Path="ActualWidth"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        <Border Height="{Binding LostChartSegHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                VerticalAlignment="Center" CornerRadius="1" MinWidth="0"
                                                                Background="#F5D0FE"
                                                                ToolTipService.ShowDuration="20000"
                                                                ToolTipService.InitialShowDelay="200"
                                                                Cursor="Hand">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="Погодні умови: оцінка втрат через погоду." TextWrapping="Wrap" MaxWidth="260"/>
                                                            </Border.ToolTip>
                                                            <TextBlock Text="{Binding WeatherCount, StringFormat={}{0}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       FontSize="{Binding LostChartSegTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="#590C6D"/>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource LostTrackWidthConv}">
                                                                    <Binding Path="WeatherTrackPercent"/>
                                                                    <Binding ElementName="LostChartScroll" Path="ActualWidth"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding TotalCount, StringFormat={}{0}}"
                                                           FontSize="{Binding LostChartLabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#0F172A"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" MinWidth="36"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock x:Name="LostChartAxisText"
                                       Grid.Row="2"
                                       FontSize="9"
                                       Foreground="#64748B"
                                       Margin="0,8,0,0"
                                       TextAlignment="Center"
                                       FontFamily="Consolas"/>

                            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding LostStackSegments}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6"
                                                        ToolTipService.ShowDuration="20000"
                                                        ToolTipService.InitialShowDelay="200">
                                                <StackPanel.ToolTip>
                                                    <TextBlock Text="{Binding TooltipHint}" TextWrapping="Wrap" MaxWidth="280"/>
                                                </StackPanel.ToolTip>
                                                <Border Width="11" Height="11" Background="{Binding BarBrush}"
                                                        BorderBrush="#4C1D95" BorderThickness="1" Margin="0,0,5,0" VerticalAlignment="Center" Cursor="Hand"/>
                                                <TextBlock Text="{Binding Label}" FontSize="8" VerticalAlignment="Center"
                                                           TextWrapping="Wrap" MaxWidth="110"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Кожен рядок має окремий накопичувальний стовпчик; довжина відносно максимуму по звіту"
                                           FontSize="8" Foreground="#666" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
