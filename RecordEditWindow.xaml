<Window x:Class="AirLiticApp.RecordEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="Редагування запису" Height="520" Width="720"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,10,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="InputControlStyle" TargetType="Control">
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Дата:" Style="{StaticResource LabelStyle}"/>
        <xctk:DateTimePicker x:Name="DatePicker"
                             Grid.Column="1"
                             Style="{StaticResource InputControlStyle}"
                             Format="ShortDate"
                             TimePickerVisibility="Collapsed"/>

        <TextBlock Grid.Row="1" Text="Час:" Style="{StaticResource LabelStyle}"/>
        <xctk:TimePicker x:Name="TimePickerControl"
                         Grid.Row="1" Grid.Column="1"
                         Style="{StaticResource InputControlStyle}"
                         Format="ShortTime"
                         EndTime="23:59:00"/>

        <TextBlock Grid.Row="2" Text="Пілот:" Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="PilotComboBox" Grid.Row="2" Grid.Column="1"
                  DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource InputControlStyle}"/>

        <TextBlock Grid.Row="3" Text="Озброєння:" Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="WeaponComboBox" Grid.Row="3" Grid.Column="1"
                  DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource InputControlStyle}"/>

        <TextBlock Grid.Row="4" Text="Результат польоту:" Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="FlyingResultComboBox" Grid.Row="4" Grid.Column="1"
                  DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource InputControlStyle}"
                  SelectionChanged="FlyingResultComboBox_SelectionChanged"/>

        <TextBlock Grid.Row="5" Text="Причина:" Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="ReasonComboBox" Grid.Row="5" Grid.Column="1"
                  DisplayMemberPath="Name" SelectedValuePath="Id" IsEnabled="False"
                  SelectionChanged="ReasonComboBox_SelectionChanged" Style="{StaticResource InputControlStyle}"/>

        <TextBlock Grid.Row="6" Text="Причина втрати:" Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="SubreasonLostDroneComboBox" Grid.Row="6" Grid.Column="1"
                  DisplayMemberPath="Name" SelectedValuePath="Id" Visibility="Visible" IsEnabled="False"
                  Style="{StaticResource InputControlStyle}"
                  SelectionChanged="SubreasonLostDroneComboBox_SelectionChanged"/>

        <TextBlock Grid.Row="7" Text="Технічні помилки:" Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="SubreasonTechComboBox" Grid.Row="7" Grid.Column="1"
                  DisplayMemberPath="Name" SelectedValuePath="Id"
                  IsEnabled="False" Style="{StaticResource InputControlStyle}"/>

        <TextBlock Grid.Row="8" Text="Опис:" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="8" Grid.Column="1"
                 Style="{StaticResource InputControlStyle}"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" MinHeight="60"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" IsDefault="True" Click="OkButton_Click"/>
            <Button Content="Скасувати" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
