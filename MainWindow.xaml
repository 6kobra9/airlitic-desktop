<Window x:Class="AirLiticApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AirLitic - Робоче вікно" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Вихід" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="Звіти">
                <MenuItem Header="Простий звіт" Click="SimpleReportMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="RecordsGrid" Grid.Row="0" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single" Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" Visibility="Collapsed"/>
                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                        Width="*" />
                    <DataGridTextColumn Header="Час" Binding="{Binding Time}" Width="*" />
                    <DataGridTextColumn Header="Пілот" Binding="{Binding PilotName}" Width="*" />
                    <DataGridTextColumn Header="Озброєння" Binding="{Binding WeaponName}" Width="*" />
                    <DataGridTextColumn Header="Результат польоту" Binding="{Binding FlyingResultName}" Width="*" />
                    <DataGridTextColumn Header="Причина" Binding="{Binding ReasonName}" Width="*" />
                    <DataGridTextColumn Header="Причина втрати" Binding="{Binding SubreasonLostDroneName}" Width="*" />
                    <DataGridTextColumn Header="Технічні проблеми" Binding="{Binding SubreasonTechName}" Width="*" />
                    <DataGridTextColumn Header="Опис" Binding="{Binding Description}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                <Button x:Name="AddButton" Content="Додати" Width="90" Margin="0,0,5,0" Click="AddButton_Click"/>
                <Button x:Name="EditButton" Content="Змінити" Width="90" Margin="0,0,5,0" Click="EditButton_Click"/>
                <Button x:Name="DeleteButton" Content="Видалити" Width="90" Click="DeleteButton_Click"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
