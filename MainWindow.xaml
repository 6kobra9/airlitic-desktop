<Window x:Class="AirLiticApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AirLitic - Робоче вікно" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/app-icon.ico">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Вихід" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="Звіти" Click="ReportsMenuItem_Click"/>
            <MenuItem x:Name="AdminMenuItem" Header="Коригування довідників" Visibility="Collapsed">
                <MenuItem Header="Пілоти" Click="PilotsMenuItem_Click"/>
                <MenuItem Header="Засоби" Click="WeaponsMenuItem_Click"/>
                <MenuItem Header="Причина втрати" Click="LostDroneReasonsMenuItem_Click"/>
                <MenuItem Header="Технічні проблеми" Click="TechProblemsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="Додати користувача" Click="AddUserMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="RecordsGrid" Grid.Row="0" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single" Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" Visibility="Collapsed"/>
                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                        Width="*" />
                    <DataGridTextColumn Header="Час" Binding="{Binding Time}" Width="*" />
                    <DataGridTextColumn Header="Пілот" Binding="{Binding PilotName}" Width="*" />
                    <DataGridTextColumn Header="Засіб" Binding="{Binding WeaponName}" Width="*" />
                    <DataGridTextColumn Header="Серійний номер" Binding="{Binding WeaponSerialNumber}" Width="*" />
                    <DataGridTextColumn Header="Частота, мГц" Binding="{Binding WeaponFrequencyMhz}" Width="*" />
                    <DataGridTextColumn Header="Тип відеосистеми" Binding="{Binding WeaponVideoTypeName}" Width="*" />
                    <DataGridTextColumn Header="Результат польоту" Binding="{Binding FlyingResultName}" Width="*" />
                    <DataGridTextColumn Header="Причина" Binding="{Binding ReasonName}" Width="*" />
                    <DataGridTextColumn Header="Причина втрати" Binding="{Binding SubreasonLostDroneName}" Width="*" />
                    <DataGridTextColumn Header="Технічні проблеми" Binding="{Binding SubreasonTechName}" Width="*" />
                    <DataGridTextColumn Header="Опис" Binding="{Binding Description}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Футер с количеством записей -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="Кількість записів: " Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding Items.Count, ElementName=RecordsGrid}"/>
                </StackPanel>

                <!-- Кнопки управления -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="AddButton" Content="Додати" Width="90" Margin="0,0,5,0" Click="AddButton_Click"/>
                    <Button x:Name="EditButton" Content="Змінити" Width="90" Margin="0,0,5,0" Click="EditButton_Click"/>
                    <Button x:Name="DeleteButton" Content="Видалити" Width="90" Click="DeleteButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
